#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import numpy as np


def assign_sites(
        atom_positions,
        site_positions):

    distances = np.linalg.norm(
        site_positions - atom_positions,
        axis=1
    )

    return np.argmin(distances)


def assign_sites_trajectory(
        u,
        sites_file="sites.dat",
        output_file="site_assignment.dat"):

    sites = np.loadtxt(
        sites_file,
        comments="#",
        dtype=str
    )

    site_ids = (
        sites[:, 0].astype(int)
    )

    elements = sites[:, 1]

    coords = (
        sites[:, 3:6].astype(float)
    )

    with open(output_file, "w") as f:

        f.write(
            "# Frame AtomID Element SiteID\n"
        )

        for iframe, ts in enumerate(
                u.trajectory):

            for atom in u.atoms:

                symbol = {
                    1: "Li",
                    2: "Mn",
                    3: "O"
                }.get(atom.type)

                if symbol not in [
                    "Li",
                    "Mn"
                ]:
                    continue

                mask = (
                    elements ==
                    symbol
                )

                local_sites = coords[mask]
                local_ids = site_ids[mask]

                d = np.linalg.norm(
                    local_sites -
                    atom.position,
                    axis=1
                )

                site = local_ids[
                    np.argmin(d)
                ]

                f.write(
                    f"{iframe} "
                    f"{atom.id} "
                    f"{symbol} "
                    f"{site}\n"
                )
